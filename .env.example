# Public (bundled into the frontend, safe)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Server-only (used inside /api/* server routes)
# El módulo de clima usa Open-Meteo (no requiere API key).
# Cuando quieras swappear a Windguru real, agregá estos secrets
# desde el panel de Lovable (NO los hardcodees acá):
#
#   WINDGURU_STATION_ID=xxxxx
#   WINDGURU_PASSWORD=xxxxx
#   WINDGURU_UID=xxxxx
#
# Ver src/routes/api/weather.ts → fetchOpenMeteo() para el punto exacto
# donde reemplazar el provider.
