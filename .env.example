# Public (bundled into the frontend, safe)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# === IA con fallback automático ===
# El asistente prueba en cadena: Lovable → OpenRouter → Groq → fallback local.
# Configurá los que quieras como secrets del backend (NO los pongas acá):
#
#   LOVABLE_API_KEY      → auto-provisionado por Lovable Cloud
#   OPENROUTER_API_KEY   → https://openrouter.ai/keys (modelos :free gratis)
#   GROQ_API_KEY         → https://console.groq.com/keys (Llama gratis)
#
# Con cualquiera de los 3 la IA sigue funcionando. Si todos fallan,
# se usa una sugerencia determinista local.

# === Clima ===
# Open-Meteo no requiere API key. Para Windguru real agregá como secrets:
#   WINDGURU_STATION_ID / WINDGURU_PASSWORD / WINDGURU_UID
